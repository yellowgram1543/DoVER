# Comma-separated list of trusted frontend origins — NO wildcards allowed
# Example: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# For local dev: CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGINS=

SESSION_SECRET=
REDIS_URL=redis://127.0.0.1:6379
NODE_ENV=development
PORT=3000